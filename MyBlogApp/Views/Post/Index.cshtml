@using MyBlogApp.Helpers
@model MyBlogApp.Models.ViewModels.PostIndexViewModel
@{
    ViewData["Title"] = "Blog Posts";
}
<div class="content-wrapper mb-4 reveal-on-load">
    <form method="get" asp-action="Index" asp-controller="Post" class="row g-3 align-items-end">
        <div class="col-12 col-md-5">
            <label class="form-label">Search</label>
            <input type="search" name="searchTerm" value="@Model.SearchTerm" class="form-control" placeholder="Search posts, content, or author" />
        </div>
        <div class="col-12 col-md-4">
            <label class="form-label">Category</label>
            <select name="categoryId" class="form-select">
                <option value="">All categories</option>
                @foreach (var category in Model.Categories)
                {
                    if (Model.CategoryId?.ToString() == category.Value)
                    {
                        <option value="@category.Value" selected>@category.Text</option>
                    }
                    else
                    {
                        <option value="@category.Value">@category.Text</option>
                    }
                }
            </select>
        </div>
        <div class="col-12 col-md-3 d-grid">
            <button type="submit" class="btn btn-primary">Filter</button>
        </div>
    </form>
</div>

<div class="text-end my-3">
    <a class="btn btn-primary" asp-action="Create" asp-controller="Post">Create New Post</a>
</div>

<div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">
    @foreach (var post in Model.Posts)
    {
        <div class="col">
            <div class="card h-100 border-0 shadow-lg rounded-1">
                <img src="@post.FeatureImagePath" class="card-img-top" alt="@post.Title" loading="lazy" style="height:300px; object-fit:cover">
                <div class="card-body">
                    <h5 class="card-title">@post.Title</h5>
                    <p class="text-muted mb-2">Published on @post.PublishedDate.ToString("MMMM dd, yyyy")</p>
                    @{
                        var content = RemoveHtmlTagHelper.RemoveHtmlTags(post.Content);
                        var postTags = post.PostTags?.Select(postTag => postTag.Tag.Name).Take(3).ToList() ?? new List<string>();
                    }
                    <p class="card-text">
                        @(content.Length > 120 ? content.Substring(0, 120) + "..." : content)
                    </p>
                    <div class="d-flex flex-wrap gap-2 mb-3">
                        @foreach (var tag in postTags)
                        {
                            <span class="tag-pill">#@tag</span>
                        }
                    </div>
                    <span class="badge bg-secondary">@post.Category?.Name</span>
                    <span class="badge bg-light text-dark ms-2">@((post.Likes?.Count ?? 0)) likes</span>
                </div>
                <div class="card-footer d-flex justify-content-between align-items-center">
                    <a asp-controller="Post" asp-action="Detail" asp-route-id="@post.Id" class="btn btn-primary btn-sm">Read More</a>
                    <div class="text-end">
                        <div class="text-muted">By @post.Author</div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@if (Model.TotalPages > 1)
{
    <nav class="mt-4" aria-label="Post pagination">
        <ul class="pagination justify-content-center">
            <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-categoryId="@Model.CategoryId" asp-route-searchTerm="@Model.SearchTerm" asp-route-pageNumber="@(Model.CurrentPage - 1)">Previous</a>
            </li>
            @for (var pageIndex = 1; pageIndex <= Model.TotalPages; pageIndex++)
            {
                <li class="page-item @(pageIndex == Model.CurrentPage ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-categoryId="@Model.CategoryId" asp-route-searchTerm="@Model.SearchTerm" asp-route-pageNumber="@pageIndex">@pageIndex</a>
                </li>
            }
            <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-categoryId="@Model.CategoryId" asp-route-searchTerm="@Model.SearchTerm" asp-route-pageNumber="@(Model.CurrentPage + 1)">Next</a>
            </li>
        </ul>
    </nav>
}