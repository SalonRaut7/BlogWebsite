@model Post
@{
    ViewData["Title"] = Model.Title;
    var tagNames = ViewBag.TagNames as IEnumerable<string> ?? Enumerable.Empty<string>();
    var likeCount = (int)(ViewBag.LikeCount ?? 0);
    var isLiked = (bool)(ViewBag.IsLiked ?? false);
    var currentUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
    var canEdit = User.IsInRole("Admin") || (Model.ApplicationUserId == currentUserId);
}

<div class="post-hero reveal-on-load">
    <div class="post-hero__meta">
        <span class="badge bg-secondary">@Model.Category.Name</span>
        <span class="text-muted">@Model.PublishedDate.ToString("MMMM dd, yyyy")</span>
    </div>
    <h1 class="display-5 fw-bold mb-3">@Model.Title</h1>
    <p class="lead text-muted mb-0">By @Model.Author</p>
</div>

<div class="content-wrapper reveal-on-load mt-4">
    <img src="@Model.FeatureImagePath" alt="@Model.Title" class="feature-image post-detail-image mb-4" />

    <div class="d-flex flex-wrap gap-2 align-items-center mb-4">
        @foreach (var tag in tagNames)
        {
            <span class="tag-pill">#@tag</span>
        }
    </div>

    <div class="d-flex flex-wrap gap-2 mb-4">
        <button type="button" class="btn btn-primary" id="likeButton" data-post-id="@Model.Id" data-liked="@(isLiked.ToString().ToLowerInvariant())">
            <span id="likeButtonText">@(isLiked ? "Unlike" : "Like")</span>
            <span class="ms-1" id="likeCount">@likeCount</span>
        </button>
        <button type="button" class="btn btn-outline-secondary" id="shareButton">Share</button>
        <button type="button" class="btn btn-outline-secondary" id="copyLinkButton">Copy Link</button>
    </div>

    @if (canEdit)
    {
        <div class="text-end mb-4">
            <a class="btn btn-secondary my-1" asp-action="Edit" asp-controller="Post" asp-route-id="@Model.Id">Edit Post</a>
            <a class="btn btn-danger mx-2 my-1" asp-action="Delete" asp-controller="Post" asp-route-id="@Model.Id">Delete Post</a>
        </div>
    }

    <article class="post-content mb-4">
        @Html.Raw(Model.Content)
    </article>

    <hr />

    <section class="reveal-on-load">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4 class="mb-0">Comments</h4>
            <span class="text-muted" id="commentCount">@Model.Comments.Count</span>
        </div>

        @if (Model.Comments.Any())
        {
            <div id="commentSection" class="comment-stack">
                @foreach (var comment in Model.Comments)
                {
                    var canManageComment = User.IsInRole("Admin") || (!string.IsNullOrWhiteSpace(currentUserId) && comment.ApplicationUserId == currentUserId);
                    <div class="comment-card card mb-3" data-comment-id="@comment.Id">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start gap-3">
                                <div>
                                    <h5 class="card-title mb-1">@comment.UserName</h5>
                                    <p class="card-text text-muted mb-2">@comment.CommentDate.ToString("MMMM dd, yyyy") @if (comment.IsEdited) { <span>(edited)</span> }</p>
                                </div>
                                @if (canManageComment)
                                {
                                    <div class="comment-actions btn-group btn-group-sm">
                                        <button type="button" class="btn btn-outline-secondary edit-comment-button" data-comment-id="@comment.Id" data-comment-content="@comment.Content">Edit</button>
                                        <button type="button" class="btn btn-outline-danger delete-comment-button" data-comment-id="@comment.Id">Delete</button>
                                    </div>
                                }
                            </div>
                            <p class="card-text comment-content" id="comment-content-@comment.Id">@comment.Content</p>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <p class="text-muted" id="emptyCommentsMessage">No comments yet. Be the first to comment!</p>
            <div id="commentSection" class="comment-stack"></div>
        }
    </section>

    @if (User.Identity?.IsAuthenticated == true)
    {
        <section class="reveal-on-load mt-4">
            <h4 class="mb-3">Add a Comment</h4>
            <form id="commentForm" class="comment-form">
                @Html.AntiForgeryToken()
                <div class="form-group mb-3">
                    <label for="Content" class="form-label">Comment</label>
                    <textarea id="Content" name="Content" class="form-control" rows="4" required></textarea>
                </div>

                <button type="submit" class="btn btn-primary mt-2 p-2 px-4">Submit Comment</button>
            </form>
        </section>
    }
    else
    {
        <div class="alert alert-info mt-4 reveal-on-load">
            <p class="mb-0">Please <a asp-controller="Account" asp-action="Login" asp-route-returnUrl="@Context.Request.Path">login</a> to add a comment.</p>
        </div>
    }
</div>

<div class="modal fade" id="commentEditorModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Edit Comment</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <textarea id="editCommentContent" class="form-control" rows="4"></textarea>
                <input type="hidden" id="editCommentId" />
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="saveCommentEdit">Save changes</button>
            </div>
        </div>
    </div>
</div>

@section Scripts{
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function(){
            const antiForgeryToken = $('input[name="__RequestVerificationToken"]').first().val();
            const commentEditorModal = new bootstrap.Modal(document.getElementById('commentEditorModal'));
            const postId = @Model.Id;

            function updateCommentCount(delta) {
                const currentCount = parseInt($('#commentCount').text(), 10) || 0;
                $('#commentCount').text(Math.max(0, currentCount + delta));
            }

            $('#likeButton').on('click', function () {
                $.ajax({
                    url: '@Url.Action("ToggleLike", "Post")',
                    type: 'POST',
                    data: { id: postId },
                    headers: {
                        'RequestVerificationToken': antiForgeryToken
                    },
                    success: function (response) {
                        $('#likeCount').text(response.likeCount);
                        $('#likeButtonText').text(response.liked ? 'Unlike' : 'Like');
                        $('#likeButton').attr('data-liked', String(response.liked));
                    }
                });
            });

            $('#shareButton').on('click', async function () {
                const shareData = {
                    title: document.title,
                    text: '@Model.Title',
                    url: window.location.href
                };

                if (navigator.share) {
                    try {
                        await navigator.share(shareData);
                    } catch (error) {
                        console.warn('Share cancelled or failed', error);
                    }
                    return;
                }

                if (navigator.clipboard) {
                    await navigator.clipboard.writeText(window.location.href);
                    alert('Link copied to clipboard.');
                }
            });

            $('#copyLinkButton').on('click', async function () {
                if (navigator.clipboard) {
                    await navigator.clipboard.writeText(window.location.href);
                    alert('Link copied to clipboard.');
                }
            });

            $('#commentForm').on('submit', function(event){
                event.preventDefault();

                var content = $('#Content').val().trim();

                if (!content) {
                    alert('Please write a comment.');
                    return;
                }

                $.ajax({
                    url: '@Url.Action("AddComment", "Post")',
                    type: 'POST',
                    contentType: 'application/json',
                    headers: {
                        'RequestVerificationToken': antiForgeryToken
                    },
                    data: JSON.stringify({
                        Content: content,
                        PostId: postId
                    }),
                    success: function(response){
                        $('#Content').val('');

                        if ($('#emptyCommentsMessage').length) {
                            $('#emptyCommentsMessage').remove();
                        }

                        const newComment = $('<div class="comment-card card mb-3" style="display:none;"></div>');
                        const body = $('<div class="card-body"></div>');
                        const header = $('<div class="d-flex justify-content-between align-items-start gap-3"></div>');
                        const authorBlock = $('<div></div>');
                        authorBlock.append($('<h5 class="card-title mb-1"></h5>').text(response.userName));
                        authorBlock.append($('<p class="card-text text-muted mb-2"></p>').text(response.commentDate));
                        header.append(authorBlock);
                        header.append($('<div class="comment-actions btn-group btn-group-sm"></div>').append(
                            $('<button type="button" class="btn btn-outline-secondary edit-comment-button">Edit</button>')
                                .attr('data-comment-id', response.id ?? 0)
                                .attr('data-comment-content', response.content),
                            $('<button type="button" class="btn btn-outline-danger delete-comment-button">Delete</button>')
                                .attr('data-comment-id', response.id ?? 0)
                        ));
                        body.append(header);
                        body.append($('<p class="card-text comment-content"></p>').text(response.content).attr('id', 'comment-content-' + (response.id ?? 0)));
                        newComment.append(body);
                        $('#commentSection').prepend(newComment);
                        newComment.fadeIn(250);
                        updateCommentCount(1);
                    },
                    error: function () {
                        alert('Something went wrong while adding your comment. Please try again.');
                    }
                });
            });

            $(document).on('click', '.edit-comment-button', function () {
                $('#editCommentId').val($(this).data('comment-id'));
                $('#editCommentContent').val($(this).data('comment-content'));
                commentEditorModal.show();
            });

            $('#saveCommentEdit').on('click', function () {
                const commentId = $('#editCommentId').val();
                const content = $('#editCommentContent').val().trim();

                if (!content) {
                    alert('Comment cannot be empty.');
                    return;
                }

                $.ajax({
                    url: '@Url.Action("EditComment", "Post")',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify({
                        id: parseInt(commentId, 10),
                        content: content
                    }),
                    headers: {
                        'RequestVerificationToken': antiForgeryToken
                    },
                    success: function (response) {
                        $('#comment-content-' + response.id).text(response.content + (response.editedAt ? ' (edited)' : ''));
                        const card = $('[data-comment-id="' + response.id + '"]');
                        card.find('.edit-comment-button').attr('data-comment-content', response.content);
                        commentEditorModal.hide();
                    },
                    error: function () {
                        alert('Unable to update the comment.');
                    }
                });
            });

            $(document).on('click', '.delete-comment-button', function () {
                if (!confirm('Delete this comment?')) {
                    return;
                }

                const commentId = $(this).data('comment-id');
                const commentCard = $(this).closest('.comment-card');

                $.ajax({
                    url: '@Url.Action("DeleteComment", "Post")',
                    type: 'POST',
                    data: { id: commentId },
                    headers: {
                        'RequestVerificationToken': antiForgeryToken
                    },
                    success: function () {
                        commentCard.fadeOut(200, function () {
                            $(this).remove();
                            updateCommentCount(-1);
                        });
                    },
                    error: function () {
                        alert('Unable to delete the comment.');
                    }
                });
            });
        });
    </script>
}