@model MyBlogApp.Models.ViewModels.AdminDashboardViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="content-wrapper mb-4">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
        <div>
            <h1 class="mb-1">Admin Dashboard</h1>
            <p class="text-muted mb-0">Content and community overview.</p>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-12 col-md-6 col-xl-3">
            <div class="card h-100 border-0">
                <div class="card-body">
                    <div class="text-muted text-uppercase small">Posts</div>
                    <div class="display-6 fw-bold">@Model.TotalPosts</div>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-6 col-xl-3">
            <div class="card h-100 border-0">
                <div class="card-body">
                    <div class="text-muted text-uppercase small">Comments</div>
                    <div class="display-6 fw-bold">@Model.TotalComments</div>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-6 col-xl-3">
            <div class="card h-100 border-0">
                <div class="card-body">
                    <div class="text-muted text-uppercase small">Users</div>
                    <div class="display-6 fw-bold">@Model.TotalUsers</div>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-6 col-xl-3">
            <div class="card h-100 border-0">
                <div class="card-body">
                    <div class="text-muted text-uppercase small">Categories</div>
                    <div class="display-6 fw-bold">@Model.TotalCategories</div>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0">
        <div class="card-header bg-transparent border-0 pt-3 pb-0">
            <h2 class="h4 mb-0">Recent Posts</h2>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Title</th>
                            <th>Category</th>
                            <th>Published</th>
                            <th class="text-end">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var post in Model.RecentPosts)
                        {
                            <tr>
                                <td>@post.Title</td>
                                <td>@post.Category?.Name</td>
                                <td>@post.PublishedDate.ToString("MMM dd, yyyy")</td>
                                <td class="text-end">
                                    <a class="btn btn-sm btn-outline-primary" asp-controller="Post" asp-action="Detail" asp-route-id="@post.Id">View</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>